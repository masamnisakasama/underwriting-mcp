        </mxCell>

        <mxCell id="note1" value="Data boundary note&#xa;Business documents, extraction output, facts, prompts, and decisions stay in AWS workload services. Cowork startup may contact Claude distribution endpoints, but this design does not send underwriting data to Anthropic API." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="1035" width="580" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="note2" value="Runtime modes&#xa;APP_MODE=mock uses in-memory stores and fixture analyzer for local demos. APP_MODE=aws swaps ports to S3, DynamoDB, and Step Functions without changing the service layer." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1035" width="560" height="110" as="geometry"/>
        </mxCell>

